{
  "hosting": {
    "site": "lingdong-price",
    "public": ".",
    "redirects": [
      {
        "source": "/",
        "destination": "/system.html",
        "type": 302
      }
    ],
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      },
      {
        "source": "**/*.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git/**",
      ".github/**",
      "backend/**",
      "tools/**",
      "downloaded_images/**",
      "download_report.csv",
      "**/*.md",
      "**/__pycache__/**",
      "**/*.pyc"
    ],
    "cleanUrls": false
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
