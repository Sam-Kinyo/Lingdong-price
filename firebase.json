{
  "hosting": {
    "site": "lingdong-price",
    "public": ".",
    "redirects": [
      {
        "source": "/",
        "destination": "/system.html",
        "type": 302
      }
    ],
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git/**",
      ".github/**",
      "backend/**",
      "tools/**",
      "**/*.md",
      "**/__pycache__/**",
      "**/*.pyc"
    ],
    "cleanUrls": false
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
